# World Cup 2026 Predictions - environment variables
# Copy to .env.local and fill in. Never commit real values.

# ── Predictions cache (Vercel KV / Upstash Redis REST) ──────────────
# Recommended. The cron writes the computed payload here and every page
# reads it. If unset, each request recomputes the 20,000-iteration sim
# (correct, just slower and more expensive), so KV is strongly advised.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Recompute cron auth ─────────────────────────────────────────────
# Shared secret protecting /api/cron/recompute. Set the same value as the
# Authorization: Bearer token your scheduler sends (Vercel Cron does this).
CRON_SECRET=

# ── Optional: public / client-side config (NEXT_PUBLIC_*, not secret) ──
# Inlined into the client bundle, so use only for non-secret values.
NEXT_PUBLIC_GA_ID=            # Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX); analytics off if unset
NEXT_PUBLIC_STUBHUB_CAMREF=   # StubHub/Partnerize affiliate camref; ticket links become tracked when set

# ── Optional: dormant auth / email backend ─────────────────────────
# The app ships fully open (no sign-in), so these are NOT required to run
# it. They only matter if you re-enable the BetterAuth + Postgres + email
# stack that powers per-user saved matches.
DATABASE_URL=          # Postgres connection string (Neon)
BETTER_AUTH_SECRET=    # random secret for BetterAuth sessions
BETTER_AUTH_URL=       # the app origin, e.g. https://example.com
RESEND_API_KEY=        # Resend API key for transactional email
EMAIL_FROM=            # From address for auth emails, e.g. "WC2026 <hello@example.com>"

# VERCEL_URL and VERCEL_PROJECT_PRODUCTION_URL are provided automatically
# by Vercel; no need to set them locally.
